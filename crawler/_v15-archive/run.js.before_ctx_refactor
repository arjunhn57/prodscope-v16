function sleep(ms) {
  return new Promise((r) => setTimeout(r, ms));
}

function executeAction(action) {
  switch (action.type) {
    case actions.ACTION_TYPES.TAP:
      adb.tap(action.bounds.cx, action.bounds.cy);
      return `tap(${action.bounds.cx}, ${action.bounds.cy}) on "${action.text || action.resourceId || 'element'}"`;

    case actions.ACTION_TYPES.TYPE:
      adb.tap(action.bounds.cx, action.bounds.cy);
      return `focus field "${action.resourceId || 'edittext'}" (filling handled by forms module)`;

    case actions.ACTION_TYPES.SCROLL_DOWN: {
      const scrollEl = findScrollableElement(null);
      gestures.scrollInBounds(scrollEl.bounds, 'down');
      return 'scroll_down';
    }

    case actions.ACTION_TYPES.SCROLL_UP: {
      const scrollEl = findScrollableElement(null);
      gestures.scrollInBounds(scrollEl.bounds, 'up');
      return 'scroll_up';
    }

    case actions.ACTION_TYPES.LONG_PRESS:
      gestures.longPress(action.bounds.cx, action.bounds.cy);
      return `long_press(${action.bounds.cx}, ${action.bounds.cy}) on "${action.text || action.resourceId || 'element'}"`;

    case actions.ACTION_TYPES.SWIPE_LEFT:
      gestures.swipeLeft(action.bounds);
      return 'swipe_left';

    case actions.ACTION_TYPES.SWIPE_RIGHT:
      gestures.swipeRight(action.bounds);
      return 'swipe_right';

    case actions.ACTION_TYPES.BACK:
      adb.pressBack();
      return 'press_back';

    default:
      console.log(`  [run] Unknown action type: ${action.type}`);
      return `unknown(${action.type})`;
  }
}

function getPrimaryPackage(xml) {
  if (!xml) return '';
  const matches = [...xml.matchAll(/package="([^"]+)"/g)].map((m) => m[1]).filter(Boolean);
  if (!matches.length) return '';
  const counts = {};
  for (const pkg of matches) counts[pkg] = (counts[pkg] || 0) + 1;
  return Object.entries(counts).sort((a, b) => b[1] - a[1])[0][0];
}

function isAllowedNonTargetPackage(pkg) {
  if (!pkg) return true;
  if (pkg === 'android') return true;
  if (pkg === 'com.android.permissioncontroller') return true;
  if (pkg === 'com.google.android.gms') return true;
  return false;
}

function isTransientEmptyXml(xml) {
  if (!xml) return true;
  const trimmed = String(xml).trim();
  if (!trimmed) return true;
  if (/null root node returned by UiTestAutomationBridge/i.test(trimmed)) return true;
  if (/^ERROR:/i.test(trimmed)) return true;
  return false;
}

function authSubmitScore(action, screenIntentType = 'unknown') {
  const haystack = `${action.text || ''} ${action.contentDesc || ''} ${action.resourceId || ''}`.toLowerCase();
  const cls = (action.className || '').toLowerCase();

  if (screenIntentType === 'email_login') {
    if (/(sign in|signin|log in|login)/i.test(haystack)) return 200;
    if (/(continue|next|submit|done|finish|verify|confirm)/i.test(haystack)) return 120;
    if (/(sign up|signup|create account|register)/i.test(haystack)) return 10;
  }

  if (screenIntentType === 'email_signup') {
    if (/(sign up|signup|create account|register)/i.test(haystack)) return 200;
    if (/(continue|next|submit|done|finish|verify|confirm)/i.test(haystack)) return 120;
    if (/(sign in|signin|log in|login)/i.test(haystack)) return 20;
  }

  if (screenIntentType === 'phone_entry') {
    if (/\bnext\b|continue|submit|proceed/.test(haystack)) return 180;
    if (/(sign up|signup|create account|register|sign in|signin|log in|login)/i.test(haystack)) return 40;
  }

  if (/(sign in|signin|log in|login)/i.test(haystack)) return 130;
  if (/(continue|next|submit|done|finish|verify|confirm|get started|start)/i.test(haystack)) return 110;
  if (/(sign up|signup|create account|register)/i.test(haystack)) return 90;
  if (cls.includes('button') && haystack.trim()) return 80;
  if (action.type === actions.ACTION_TYPES.TAP && haystack.trim()) return 60;
  return 0;
}

function findBestAuthSubmitAction(candidates, screenIntentType = 'unknown') {
  const submitCandidates = candidates.filter((a) => {
    if (a.type !== actions.ACTION_TYPES.TAP) return false;
    const haystack = `${a.text || ''} ${a.contentDesc || ''} ${a.resourceId || ''}`.toLowerCase();
    return /(sign up|signup|create account|register|sign in|signin|log in|login|continue|next|submit|done|finish|verify|confirm|get started|start)/i.test(haystack);
  });

  if (!submitCandidates.length) return null;

  submitCandidates.sort((a, b) => authSubmitScore(b, screenIntentType) - authSubmitScore(a, screenIntentType));
  return submitCandidates[0];
}

function makeAuthSubmitKey(action) {
  return (
    action.text ||
    action.resourceId ||
    action.contentDesc ||
    'auth_submit_unknown'
  )
    .toLowerCase()
    .replace(/\s+/g, ' ')
    .trim();
}

function hasValidationErrorText(xml) {
  if (!xml) return false;
  return /(invalid|required|already exists|already registered|password must|enter a valid|try again|error|incorrect|failed|unable|not available)/i.test(xml);
}

/**
 * Vision-only WebView auth navigator.
 * When tapping an auth choice leads to a WebView (UIAutomator XML fails),
 * this uses screencap + vision AI to navigate the login form.
 *
 * CRITICAL: Never calls adb.dumpXml() — UIAutomator dump on WebViews
 * crashes the UIAutomator service and corrupts the ADB connection.
 * Uses adb.getCurrentPackage() to detect return to native app.
 */
async function navigateWebViewAuth(screenshotDir, stepBase, credentials, preferredMethod, packageName) {
  const MAX_VISION_AUTH_STEPS = 8;

  const emailOrUser = credentials.email || credentials.username || '';
  const password = credentials.password || '';

  // Track what we've done so we don't repeat
  let typedEmail = false;
  let typedPassword = false;

  // Wait for screen transition — WebViews take time to load
  await sleep(4000);

  for (let i = 0; i < MAX_VISION_AUTH_STEPS; i++) {
    // Take screenshot only — NO XML dump
    const ssPath = path.join(screenshotDir, `webview_auth_${stepBase}_${i}.png`);
    let screencapOk = false;
    try {
      screencapOk = adb.screencap(ssPath);
    } catch (_) {}

    if (!screencapOk || !fs.existsSync(ssPath) || fs.statSync(ssPath).size === 0) {
      console.log(`  [webview-auth] Step ${i + 1}: screencap failed — waiting`);
      await sleep(3000);
      continue;
    }

    // Check if we're back in the target app (NOT using dumpXml)
    try {
      const currentPkg = adb.getCurrentPackage();
      if (currentPkg && currentPkg === packageName) {
        console.log(`  [webview-auth] Step ${i + 1}: back in ${currentPkg} — auth may have completed`);
        return { navigated: true, stepsUsed: i + 1, backInNative: true };
      }
    } catch (_) {}

    if (vision.budgetRemaining() <= 0) {
      console.log('  [webview-auth] Vision budget exhausted — pressing back');
      adb.pressBack();
      return { navigated: false, stepsUsed: i + 1, reason: 'vision_budget' };
    }

    // Build a specific goal based on what we've already done
    let goal;
    if (!typedEmail) {
      goal = `I just tapped a login option and this screen appeared. I need to sign in with ${preferredMethod}. Look at this screen carefully. If you see an email or username text input field, tell me to tap it. If you see a text input that is already focused (has cursor), tell me to type in it. Do NOT describe buttons like "Use email" or "Continue with email" — I need the actual text INPUT FIELD where I type my email address.`;
    } else if (!typedPassword) {
      goal = `I already typed my email/username. Now I need to enter my password. Look for a password input field. If you see one, tell me to tap it. If a field is already focused, tell me to type.`;
    } else {
      goal = `I already typed email and password. Now I need to submit the form. Look for a "Sign in", "Log in", "Submit", or "Continue" button and tell me to tap it.`;
    }

    const guidance = await vision.getVisionGuidance(ssPath, '', {
      classification: 'webview_auth',
      triedCount: i,
      goal,
    });

    if (!guidance || !guidance.mainActions || guidance.mainActions.length === 0) {
      console.log(`  [webview-auth] Step ${i + 1}: vision returned no actions`);
      // Don't give up immediately — wait and retry
      if (i < 2) {
        await sleep(3000);
        continue;
      }
      console.log('  [webview-auth] No actions after multiple attempts — pressing back');
      adb.pressBack();
      await sleep(1000);
      return { navigated: false, stepsUsed: i + 1, reason: 'no_actions' };
    }

    const action = guidance.mainActions[0];
    const desc = (action.description || '').toLowerCase();
    console.log(`  [webview-auth] Step ${i + 1}: vision says "${action.description}" at (${action.x}, ${action.y})`);

    // Tap the element
    adb.tap(action.x, action.y);
    await sleep(1000);

    // Decide what to do based on our state, not the description keywords
    if (!typedEmail) {
      // We're looking for the email field — type it
      console.log(`  [webview-auth] Typing email/username: ${emailOrUser.slice(0, 3)}***`);
      adb.inputText(emailOrUser);
      typedEmail = true;
      await sleep(800);
      // Try to advance to next field
      adb.run('adb shell input keyevent KEYCODE_TAB', { ignoreError: true });
      await sleep(500);
    } else if (!typedPassword) {
      // We're looking for the password field — type it
      console.log('  [webview-auth] Typing password');
      adb.inputText(password);
      typedPassword = true;
      await sleep(800);
    } else {
      // We've typed both — this tap should be the submit button
      console.log('  [webview-auth] Submit button tapped — waiting for redirect');
      await sleep(5000);
      return { navigated: true, stepsUsed: i + 1, backInNative: false };
    }

    await sleep(1500);
  }

  console.log('  [webview-auth] Max steps reached — pressing back');
  adb.pressBack();
  await sleep(1000);
  return { navigated: false, stepsUsed: MAX_VISION_AUTH_STEPS, reason: 'max_steps' };
}

async function captureStableScreen(screenshotDir, index, maxRetries = 3, retryDelayMs = 1000) {
  let snapshot = null;

  for (let attempt = 0; attempt <= maxRetries; attempt++) {
    snapshot = screen.capture(screenshotDir, index);

    if (!snapshot || snapshot.error === 'capture_failed' || snapshot.error === 'device_offline') {
      return snapshot;
    }

    if (!isTransientEmptyXml(snapshot.xml)) {
      return snapshot;
    }

    console.log(`  [crawler] Transient empty/null XML on capture ${index} (attempt ${attempt + 1}/${maxRetries + 1})`);
    if (attempt < maxRetries) {
      // On second attempt, try to clear any ANR dialog blocking uiautomator
      if (attempt === 1) adb.dismissAnrIfPresent();
      await sleep(retryDelayMs);
    }
  }

  // XML failed but screenshot succeeded — return partial snapshot for vision-only processing
  if (snapshot && isTransientEmptyXml(snapshot.xml) && snapshot.screenshotPath) {
    snapshot.xmlFailed = true;
    console.log(`  [crawler] XML dump failed but screenshot available — proceeding vision-only`);
  }

  return snapshot;
}

async function runCrawl(config) {
  const ctx = new CrawlContext(config);

  console.log(`[crawler] Starting crawl for package=${ctx.packageName}, maxSteps=${ctx.maxSteps}`);
  console.log(`[crawler] Credentials provided: ${!!ctx.hasValidCredentials}, goldenPath: ${!!ctx.goldenPath}`);

  // ── Initialize core state ──
  ctx.stateGraph = new graph.StateGraph();
  ctx.metrics = new CrawlMetrics();

  // ── Initialize module instances ──
  ctx.recoveryManager = new RecoveryManager({
    packageName: ctx.packageName,
    launcherActivity: ctx.launcherActivity,
    stateGraph: ctx.stateGraph,
    adb,
    readiness,
    fingerprint,
    getHomeFingerprint: () => ctx.homeFingerprint,
    sleep,
  });

  ctx.modeManager = new ModeManager(ctx.maxSteps);
  ctx.appState = new AppState();
  ctx.flowTracker = FlowTracker ? new FlowTracker() : null;
  ctx.dedup = FlowDeduplicator ? new FlowDeduplicator() : null;
  ctx.watchdog = EmulatorWatchdog ? new EmulatorWatchdog(ctx.packageName) : null;
  ctx.coverageTracker = CoverageTracker ? new CoverageTracker() : null;
  vision.resetBudget();

  // ── Convenience aliases (read-only shortcuts used throughout the loop) ──
  const { screenshotDir, packageName, credentials, maxSteps, launcherActivity,
    hasValidCredentials, stateGraph, screens, actionsTaken, metrics } = ctx;
  // NOTE: mutable state must always be read/written via ctx.* directly.
  // These aliases are only for immutable config and object references.

  function sendLiveProgress(step, extra = {}) {
    if (!ctx.onProgress) return;
    ctx.onProgress({
      phase: 'running',
      rawStep: step,
      maxRawSteps: maxSteps,
      countedUniqueScreens: stateGraph.uniqueStateCount(),
      targetUniqueScreens: maxSteps,
      activity: extra.activity || '',
      intentType: extra.intentType || '',
      latestAction: ctx.lastLiveAction,
      message: extra.message || 'Step ' + (step + 1) + '/' + maxSteps,
      captureMode: 'screenshot',
      packageName,
      path: extra.path || '',
    });
  }

  function formatJournal() {
    if (ctx.explorationJournal.length === 0) return "";
    return "EXPLORATION HISTORY (recent):\n" +
      ctx.explorationJournal.map((j) =>
        `  Step ${j.step}: ${j.screen} -> ${j.action} -> ${j.outcome}${j.isNew ? " [NEW]" : ""}`
      ).join("\n");
  }

  for (let step = 0; step < maxSteps; step++) {
    metrics.recordStepStart(step);
    sendLiveProgress(step, { message: "Starting step " + (step + 1) + "/" + maxSteps });
    console.log(`\n[crawler] === Step ${step + 1}/${maxSteps} ===`);

    // Watchdog health check every 5 steps
    if (watchdog && step > 0 && step % 5 === 0) {
      const health = watchdog.checkHealth();
      if (!health.healthy) {
        console.log(`  [watchdog] Unhealthy: ${health.action} — ${health.detail}`);
        const recovered = await watchdog.recover(health.action);
        if (!recovered) {
          stopReason = 'emulator_failure';
          break;
        }
        if (watchdog.reportProgress) watchdog.reportProgress();
        continue;
      }
    }

    if (!adb.isDeviceOnline()) {
      consecutiveDeviceFails++;
      console.log(`  [crawler] Device offline (attempt ${consecutiveDeviceFails}/${MAX_DEVICE_FAILS})`);
      if (consecutiveDeviceFails >= MAX_DEVICE_FAILS) {
        stopReason = 'device_offline';
        break;
      }
      await sleep(3000);
      continue;
    }
    consecutiveDeviceFails = 0;

    const snapshot = await captureStableScreen(screenshotDir, step, 3, 2000);

    if (!snapshot || snapshot.error === 'capture_failed') {
      consecutiveCaptureFails++;
      console.log(`  [crawler] Screenshot capture failed (${consecutiveCaptureFails}/${MAX_CAPTURE_FAILS})`);
      if (consecutiveCaptureFails >= MAX_CAPTURE_FAILS) {
        totalCaptureRecoveries++;
        if (totalCaptureRecoveries > MAX_CAPTURE_RECOVERIES) {
          console.log(`  [crawler] Capture recovery failed ${totalCaptureRecoveries} times total — giving up`);
          stopReason = 'capture_failed';
          break;
        }
        console.log(`  [crawler] Max capture fails reached — attempting recovery (${totalCaptureRecoveries}/${MAX_CAPTURE_RECOVERIES})`);
        const recResult = await recoveryManager.recover(SITUATION.EMPTY_SCREEN, 'capture_failed');
        if (recResult.success) {
          console.log('  [crawler] Recovery succeeded after capture failures — resuming crawl');
          consecutiveCaptureFails = 0;
          continue;
        }
        stopReason = 'capture_failed';
        break;
      }
      await sleep(2000);
      continue;
    }

    // XML failed but screenshot available — use vision-only for this step
    if (snapshot.xmlFailed) {
      console.log(`  [crawler] Vision-only step ${step} (XML unavailable)`);
      consecutiveCaptureFails = 0; // screenshot worked, reset counter

      // Use screenshot path as a basic fingerprint (file size + step as proxy)
      const visionOnlyFp = `vonly_step${step}`;

      // Ask vision what to do with just the screenshot
      let visionOnlyResult = null;
      if (vision.budgetRemaining() > 0) {
        try {
          visionOnlyResult = await vision.getVisionGuidance(
            snapshot.screenshotPath, '',
            {
              classification: 'unknown',
              triedCount: step,
              goal: plan ? plan.targets[0] : 'explore the app',
              previousAction: lastActionOutcome,
              journal: formatJournal(),
            }
          );
        } catch (e) {
          console.warn(`  [vision] Vision-only call failed: ${e.message}`);
        }
      }

      if (visionOnlyResult && visionOnlyResult.mainActions && visionOnlyResult.mainActions.length > 0) {
        // Execute the top vision action directly
        const topAction = visionOnlyResult.mainActions[0];
        console.log(`  [vision-only] Executing: ${topAction.description} at (${topAction.x}, ${topAction.y})`);
        adb.tap(topAction.x, topAction.y);
        actionsTaken.push({
          step,
          type: 'tap',
          description: `vision-only: ${topAction.description}`,
          actionKey: `tap:vision:${topAction.x},${topAction.y}`,
          fromFingerprint: visionOnlyFp,
        });
        await sleep(1500);
      } else {
        // No vision guidance available — press back as safe fallback
        console.log(`  [vision-only] No vision guidance — pressing back`);
        adb.pressBack();
        actionsTaken.push({ step, type: 'back', description: 'vision-only fallback back', fromFingerprint: visionOnlyFp });
        await sleep(1000);
      }

      if (typeof onProgress === 'function') {
        onProgress({ step, totalSteps: maxSteps, action: 'vision_only_step', screens: screens.length });
      }
      continue;
    }

    if (snapshot.error === 'device_offline') {
      consecutiveDeviceFails++;
      console.log(`  [crawler] Device lost during capture (${consecutiveDeviceFails}/${MAX_DEVICE_FAILS})`);
      if (consecutiveDeviceFails >= MAX_DEVICE_FAILS) {
        stopReason = 'device_offline';
        break;
      }
      await sleep(3000);
      continue;
    }

    consecutiveCaptureFails = 0;
    consecutiveDeviceFails = 0;

    // Loading detection — wait for content before acting
    const loadResult = await waitForContentLoad(snapshot.xml);
    if (loadResult.isLoading) {
      snapshot.xml = loadResult.xml; // use the post-loading XML
    }

    snapshot.step = step;
    screens.push(snapshot);

    const primaryPackage = getPrimaryPackage(snapshot.xml);
    console.log(`  [crawler] Primary package: ${primaryPackage || 'unknown'}`);

    const screenIntent = detectScreenIntent(snapshot.xml);
    console.log(`  [intent] type=${screenIntent.type} confidence=${screenIntent.confidence}`);

    // Update live preview — frontend will see the new screenshot
    sendLiveProgress(step, {
      activity: snapshot.activity || '',
      intentType: screenIntent.type || '',
      message: `Captured screen ${step + 1} — ${snapshot.activity || 'unknown'}`,
      path: snapshot.screenshotPath || '',
    });

    // Out-of-app check MUST run BEFORE system handlers
    if (primaryPackage && primaryPackage !== packageName && !isAllowedNonTargetPackage(primaryPackage)) {
      outOfAppRecoveries++;
      console.log(`  [crawler] Out-of-app screen detected: ${primaryPackage} (target=${packageName})`);

      // Record out_of_app outcome for the action that caused this
      if (lastActionKey && lastActionFromFp) {
        stateGraph.recordOutcome(lastActionFromFp, lastActionKey, 'out_of_app');
        console.log(`  [crawler] Action "${lastActionKey}" -> out_of_app (marked on ${lastActionFromFp.slice(0, 8)})`);
        lastActionKey = null;
        lastActionFromFp = null;
      }

      if (outOfAppRecoveries > MAX_OUT_OF_APP_RECOVERIES) {
        stopReason = 'left_target_app';
        break;
      }

      const oaResult = await recoveryManager.recover(SITUATION.OUT_OF_APP, 'out_of_app');
      if (!oaResult.success) {
        // Recovery manager failed — try manual relaunch with force-stop of wrong package
        console.log(`  [crawler] Standard recovery failed — attempting manual relaunch (force-stop ${primaryPackage}, launch ${packageName})`);
        let manualRecovered = false;
        for (let attempt = 1; attempt <= 3; attempt++) {
          try {
            // Kill the wrong package that hijacked the foreground
            adb.run(`adb shell am force-stop ${primaryPackage}`, { ignoreError: true });
            await sleep(1500);

            // Force-stop the target too (clean slate) then relaunch
            adb.run(`adb shell am force-stop ${packageName}`, { ignoreError: true });
            await sleep(500);

            // Try explicit activity launch first (most reliable)
            if (launcherActivity) {
              adb.run(`adb shell am start -W -n ${packageName}/${launcherActivity}`, { ignoreError: true });
            }
            // Always also try monkey as backup (am start may silently fail)
            adb.run(`adb shell monkey -p ${packageName} -c android.intent.category.LAUNCHER 1`, { ignoreError: true });
            await sleep(3000 + attempt * 1000); // 4s, 5s, 6s — give app time to load

            // Check if target app is running — use pidof (lightweight, doesn't depend on dumpsys)
            const pidCheck = adb.run(`adb shell pidof ${packageName}`, { ignoreError: true });
            const hasPid = pidCheck && pidCheck.trim().length > 0;

            // Also try dumpsys-based check as secondary signal
            const currentPkg = adb.getCurrentPackage();
            const isTarget = currentPkg === packageName;

            // Also check XML for package presence
            let xmlPkg = null;
            if (!isTarget) {
              const xml = adb.dumpXml();
              if (xml) xmlPkg = getPrimaryPackage(xml);
            }

            if (isTarget || xmlPkg === packageName || hasPid) {
              console.log(`  [crawler] Manual relaunch succeeded on attempt ${attempt} (dumpsys=${currentPkg}, xml=${xmlPkg}, pid=${hasPid})`);
              manualRecovered = true;
              break;
            }
            console.log(`  [crawler] Manual relaunch attempt ${attempt}/3 — dumpsys=${currentPkg}, xml=${xmlPkg}, pid=${hasPid}`);
          } catch (e) {
            console.warn(`  [crawler] Manual relaunch attempt ${attempt}/3 failed: ${e.message}`);
          }
        }
        if (!manualRecovered) {
          stopReason = 'left_target_app';
          break;
        }
      }
      // After recovery, suppress saturation-back for 3 steps so the crawler
      // can navigate away from the screen that caused the exit.
      saturationCooldown = 3;
      continue;
    }

    // If no valid credentials and we hit an auth screen, skip it immediately
    const AUTH_INTENT_TYPES = new Set([
      'email_login', 'email_signup', 'email_entry',
      'phone_entry', 'otp_verification', 'auth_choice',
    ]);
    if (!hasValidCredentials && AUTH_INTENT_TYPES.has(screenIntent.type)) {
      console.log(`  [crawler] Auth screen (${screenIntent.type}) detected but no credentials provided — pressing back to skip`);
      adb.pressBack();
      await sleep(800);
      continue;
    }

    // Auth screens use dialog/bottomsheet components but are NOT system interrupts.
    // When we have valid credentials, skip system handler for auth screens so the
    // credential-aware auth flow can handle them intelligently.
    const isAuthScreen = hasValidCredentials && AUTH_INTENT_TYPES.has(screenIntent.type);

    let sysResult = { handled: false, action: null, handler: null };
    if (!isAuthScreen) {
      sysResult = systemHandlers.check(snapshot.xml);
      if (sysResult.handled) {
        consecutiveSysHandlerSteps++;
        if (consecutiveSysHandlerSteps >= 5) {
          console.log('  [crawler] 5+ consecutive system handler steps — force recovery');
          consecutiveSysHandlerSteps = 0;
          await recoveryManager.recover(SITUATION.STUCK_SAME_SCREEN, 'sys_handler_stuck');
          continue;
        }
        actionsTaken.push({
          step,
          type: 'system_handler',
          handler: sysResult.handler,
          description: sysResult.action,
        });
        await sleep(800);
        lastActionKey = null;
        lastActionFromFp = null;
        continue;
      }
    } else {
      console.log(`  [crawler] Auth screen (${screenIntent.type}) — bypassing system handler`);
    }
    consecutiveSysHandlerSteps = 0;

    outOfAppRecoveries = 0;

    const fp = fingerprint.compute(snapshot.xml);
    const fuzzyFp = fingerprint.computeFuzzy(snapshot.xml, snapshot.activity);
    snapshot.fuzzyFp = fuzzyFp;

    // Screenshot-based perceptual hash — stable even when XML is garbage
    const ssFp = snapshot.screenshotPath ? screenshotFp.computeHash(snapshot.screenshotPath) : null;
    snapshot.screenshotHash = ssFp;

    const isNew = !stateGraph.isVisited(fp);

    // Cycling-loop detection: if the last CYCLE_WINDOW steps only visited
    // CYCLE_UNIQUE_THRESHOLD or fewer unique fingerprints, we're stuck in a
    // dynamic-content loop (e.g. a date picker). Press BACK to escape.
    recentFpWindow.push(fp);
    if (recentFpWindow.length > CYCLE_WINDOW) recentFpWindow.shift();
    if (recentFpWindow.length >= CYCLE_WINDOW) {
      const uniqueInWindow = new Set(recentFpWindow).size;
      if (uniqueInWindow <= CYCLE_UNIQUE_THRESHOLD && fp !== homeFingerprint) {
        console.log(`  [crawler] Cycling-loop detected: only ${uniqueInWindow} unique fps in last ${CYCLE_WINDOW} steps — pressing back to escape`);
        adb.pressBack();
        recentFpWindow.length = 0; // reset window after escape
        actionsTaken.push({ step, type: 'back', description: 'press_back', reason: 'cycle_loop_escape', fromFingerprint: fp });
        await sleep(500);
        modeManager.recordStep();
        continue;
      }
    }

    // Track home screen (first screen = app root — never press BACK from it)
    if (!homeFingerprint && fp !== 'empty_screen') homeFingerprint = fp;

    // Track new screen exploration
    if (isNew) {
      lastNewScreenFp = fp;
      actionsOnNewScreen = 0;
    }

    console.log(
      `  [crawler] Fingerprint: ${fp} (${isNew ? 'NEW' : 'visited ' + stateGraph.visitCount(fp) + 'x'}) activity=${snapshot.activity}`,
    );

    if (fp === 'empty_screen') {
      console.log('  [crawler] Empty screen detected - recovery');
      await recoveryManager.recover(SITUATION.EMPTY_SCREEN, fp);
      continue;
    }

    if (authFlowActive) {
      if (screenIntent.type.startsWith('auth') || screenIntent.type.includes('login') || screenIntent.type.includes('signup') || screenIntent.type === 'email_entry' || screenIntent.type === 'phone_entry' || screenIntent.type === 'otp_verification') {
        authFlowStepsRemaining = AUTH_FLOW_MAX_STEPS;
        console.log('  [crawler] Auth flow still active');
      } else {
        authFlowStepsRemaining--;
        if (authFlowStepsRemaining <= 0) {
          authFlowActive = false;
          lastAuthSubmitKey = null;
          consecutiveSameAuthSubmit = 0;
          console.log('  [crawler] Auth flow expired');
        }
      }
    }

    if (isNew) {
      consecutiveNoNewState = 0;
    } else {
      consecutiveNoNewState++;
      if (consecutiveNoNewState >= MAX_NO_NEW_STATE) {
        console.log(`  [crawler] ${MAX_NO_NEW_STATE} consecutive steps with no new state - stopping`);
        stopReason = 'no_new_states';
        stateGraph.addState(fp, snapshot);
        break;
      }
    }

    // ── Discovery rate tracking — detect exhausted exploration ──
    discoveryWindow.push(isNew);
    if (discoveryWindow.length > DISCOVERY_WINDOW_SIZE) discoveryWindow.shift();

    if (step >= discoveryStopEligibleStep && discoveryWindow.length >= DISCOVERY_WINDOW_SIZE) {
      const newInWindow = discoveryWindow.filter(Boolean).length;
      const allSaturated = coverageTracker
        ? coverageTracker.allSaturated()
        : false;

      if (newInWindow < DISCOVERY_MIN_RATE && allSaturated) {
        console.log(`  [crawler] Exploration exhausted: ${newInWindow} new screens in last ${DISCOVERY_WINDOW_SIZE} steps, all features saturated — stopping early`);
        stopReason = 'exploration_exhausted';
        stateGraph.addState(fp, snapshot);
        break;
      }
    }

    stateGraph.addState(fp, snapshot);

    // ── Brain: classify screen + track coverage + create plan ──
    let classification = null;
    if (classify) {
      classification = classify(snapshot.xml, snapshot.activity, fp);
      snapshot.screenType = classification.type;
      snapshot.feature = classification.feature;
      console.log(`  [brain] Screen: ${classification.type} (${classification.feature}) confidence=${classification.confidence}`);

      // ── XML quality scoring + effective fingerprint ──
      const preVisionCandidates = actions.extract(snapshot.xml, stateGraph.triedActionsFor(fp));
      const xmlQ = assessXmlQuality(snapshot.xml, classification, preVisionCandidates.length);
      // When XML is unreliable, use screenshot hash as the effective fingerprint
      const effectiveFp = (xmlQ.visionPrimary && ssFp && ssFp !== 'no_screenshot') ? 'ss_' + ssFp : fp;
      if (xmlQ.visionPrimary) {
        console.log(`  [xml-quality] score=${xmlQ.score.toFixed(2)} [${xmlQ.reasons.join(', ')}] → vision-primary (effectiveFp=${effectiveFp.slice(0, 16)})`);
      }

      // ── Vision fallback: call vision API for ambiguous/Compose screens ──
      // In vision-primary mode (low XML quality), always call vision if budget allows
      // Otherwise, only call when classification confidence is low
      visionResult = null;
      const shouldCallVision = xmlQ.visionPrimary
        ? vision.budgetRemaining() > 0
        : (classification.confidence < 0.5 && vision.needsVision(snapshot.xml, classification, preVisionCandidates));
      if (shouldCallVision) {
        try {
          visionResult = await vision.getVisionGuidance(
            snapshot.screenshotPath, snapshot.xml,
            {
              classification: classification.type,
              triedCount: step,
              goal: plan ? plan.targets[0] : 'explore the app',
              previousAction: lastActionOutcome,
              journal: formatJournal(),
            }
          );
          if (visionResult && visionResult.screenType) {
            console.log(`  [vision] Override: ${classification.type} -> ${visionResult.screenType}`);
            classification.type = visionResult.screenType === 'nav_hub' ? 'navigation_hub' : visionResult.screenType;
            classification.confidence = 0.7;
            classification.classifiedBy = 'vision';
            classification.feature = VISION_SCREEN_TO_FEATURE[visionResult.screenType] || 'other';
            snapshot.screenType = classification.type;
            snapshot.feature = classification.feature;
          }
          // Filter out navigation/back actions — crawler handles navigation itself
          if (visionResult && visionResult.mainActions) {
            const before = visionResult.mainActions.length;
            visionResult.mainActions = visionResult.mainActions.filter(
              (a) => !VISION_NAV_FILTER.test(a.description || '')
            );
            if (visionResult.mainActions.length < before) {
              console.log(`  [vision] Filtered ${before - visionResult.mainActions.length} nav actions (back/home/return)`);
            }
          }
          // Cache vision result keyed by effective FP (screenshot hash for Compose, XML FP otherwise)
          if (visionResult) visionActionCache.set(effectiveFp, visionResult);
        } catch (e) {
          console.warn(`  [vision] Error: ${e.message}`);
        }
      }
      // On revisit: check cache by effective FP first, then try fuzzy screenshot match
      if (!visionResult && visionActionCache.has(effectiveFp)) {
        visionResult = visionActionCache.get(effectiveFp);
        console.log(`  [vision] Using cached actions for ${effectiveFp.slice(0, 16)} (${(visionResult.mainActions || []).length} actions)`);
      }
      if (!visionResult && ssFp && ssFp !== 'no_screenshot') {
        // Fuzzy screenshot cache lookup — find cached result within hamming distance 8
        for (const [cachedKey, cachedResult] of visionActionCache) {
          if (cachedKey.startsWith('ss_')) {
            const cachedSsHash = cachedKey.slice(3);
            if (screenshotFp.isSameScreen(ssFp, cachedSsHash, 8)) {
              visionResult = cachedResult;
              console.log(`  [vision] Fuzzy screenshot cache hit: ${cachedKey.slice(0, 16)} (hamming ≤8, ${(cachedResult.mainActions || []).length} actions)`);
              break;
            }
          }
        }
      }

      // Decrement saturation cooldown (set after out-of-app recovery)
      if (saturationCooldown > 0) saturationCooldown--;

      // Split "other" feature by fingerprint — prevents cross-contamination
      // where profile saturating "other" also blocks notifications, etc.
      if (classification.feature === 'other') {
        classification.feature = `other_${fp.slice(0, 8)}`;
        snapshot.feature = classification.feature;
      }

      // Track coverage
      if (coverageTracker) {
        coverageTracker.recordVisit(classification.feature, fp, classification.type);

        // Skip saturated features — don't waste steps on well-tested areas
        // But ONLY when the classifier is confident (>0.3). For Compose/Flutter/RN apps
        // where everything is 'unknown/other' with low confidence, skipping would
        // cause the crawler to press BACK repeatedly and exit the app.
        // Also skip during cooldown after recovery — pressing BACK immediately
        // after relaunch often exits the app again.
        const canSaturationBack = saturationCooldown === 0 && fp !== homeFingerprint;
        if (coverageTracker.isSaturated(classification.feature) && !isNew && classification.confidence > 0.3) {
          if (!canSaturationBack) {
            const reason = fp === homeFingerprint ? 'on HOME' : `cooldown (${saturationCooldown} steps left)`;
            console.log(`  [brain] Feature "${classification.feature}" saturated but ${reason} — skipping back`);
          } else {
            console.log(`  [brain] Feature "${classification.feature}" is saturated — pressing back to explore elsewhere`);
            adb.pressBack();
            actionsTaken.push({ step, type: 'back', description: 'press_back', reason: 'feature_saturated', fromFingerprint: fp });
            await sleep(500);
            // Saturation-back is navigation, not failed exploration — don't accumulate no-new-state
            consecutiveNoNewState = 0;  // saturation-back is intentional nav, not failed exploration
            modeManager.recordStep();
            continue;
          }
        } else if (coverageTracker.isSaturated(classification.feature) && !isNew && classification.confidence <= 0.3) {
          // For form/data_entry: force BACK even at low confidence — typing more fields isn't exploration
          if (classification.feature === 'data_entry' && canSaturationBack) {
            console.log(`  [brain] Feature "data_entry" saturated — forcing back despite low confidence`);
            adb.pressBack();
            actionsTaken.push({ step, type: 'back', description: 'press_back', reason: 'form_saturated', fromFingerprint: fp });
            await sleep(500);
            consecutiveNoNewState = 0;  // saturation-back is intentional nav, not failed exploration
            modeManager.recordStep();
            continue;
          }
          console.log(`  [brain] Feature "${classification.feature}" saturated but confidence too low (${classification.confidence}) — continuing exploration`);
        }
      }

      // Dedup: skip fuzzy-duplicate screens in well-covered features
      if (dedup && fuzzyFp && classification && coverageTracker) {
        const cat = coverageTracker.categories[classification.feature];
        const seenFuzzyFps = cat ? cat.uniqueFingerprints : new Set();
        const dupResult = dedup.shouldSkipScreen(classification.feature, fuzzyFp, seenFuzzyFps, snapshot.xml);
        if (dupResult.skip && !isNew && fp !== homeFingerprint) {
          console.log(`  [dedup] Skipping fuzzy duplicate: ${dupResult.reason}`);
          adb.pressBack();
          actionsTaken.push({ step, type: 'back', description: 'press_back', reason: 'dedup_skip', fromFingerprint: fp });
          modeManager.recordStep();
          await readiness.waitForScreenReady({ timeoutMs: 1500 });
          continue;
        }
        dedup.updateFeatureProfile(classification.feature, snapshot.xml);
      }

      // Create strategic plan on first meaningful screen (1 LLM call)
      if (!plan && createInitialPlan && step <= 2) {
        try {
          plan = await createInitialPlan(
            { packageName, activities: [], permissions: [], appName: '' },
            { goals: goals || '', painPoints: painPoints || '', goldenPath: goldenPath || '' },
            classification.type === 'navigation_hub' ? 'app_with_tabs' : 'general'
          );
          console.log(`  [brain] Plan created: ${plan.targets.join(' -> ')} (${plan.priority})`);
        } catch (e) {
          console.warn(`  [brain] Plan creation failed: ${e.message}`);
        }
      }

      // Advance plan target if current target is covered
      if (plan && coverageTracker && currentTarget) {
        const ct = currentTarget(plan);
        if (ct && coverageTracker.isCovered(ct)) {
          console.log(`  [brain] Target "${ct}" is covered — advancing to next`);
          advanceTarget(plan);
          const next = currentTarget(plan);
          if (next) console.log(`  [brain] New target: ${next}`);
        }
      }

      // Detect navigation structure on first content screen
      if (!navStructure && step <= 5 && classification &&
        (classification.type === 'navigation_hub' || classification.type === 'feed')) {
        navStructure = detectNavigationStructure(snapshot.xml);
        if (navStructure.type !== 'none') {
          console.log(`  [navigator] Detected ${navStructure.type} with ${navStructure.sections.length} sections`);
        }
        // Vision fallback: when XML finds no nav (common for Compose/Flutter)
        if (navStructure.type === 'none' && snapshot.screenshotPath && vision.budgetRemaining() > 0) {
          console.log('  [navigator] XML nav detection found nothing — trying vision fallback');
          try {
            const visionTabs = await vision.detectNavTabs(snapshot.screenshotPath);
            if (visionTabs) {
              navStructure = buildNavFromVision(visionTabs);
            }
          } catch (e) {
            console.warn(`  [navigator] Vision nav detection failed: ${e.message}`);
          }
        }
      }

      // Flow tracking — record screen visit
      if (flowTracker) {
        flowTracker.addStep(classification.type, '', '', fp);
        if (classification.type === 'navigation_hub') {
          flowTracker.checkFlowComplete(classification.type, true);
        }
      }

      // Paywall detection
      if (appState.checkPaywall(snapshot.xml, fp)) {
        console.log('  [appState] Paywall detected — pressing back');
        adb.pressBack();
        await readiness.waitForScreenReady({ timeoutMs: 2000 });
        modeManager.recordStep();
        continue;
      }
      if (appState.paywallScreenFps.has(fp)) {
        console.log('  [appState] Returning to known paywall — pressing back');
        adb.pressBack();
        modeManager.recordStep();
        continue;
      }

      // SURVEY mode: systematically visit navigation sections
      if (navStructure && navStructure.type !== 'none') {
        const hasUnvisitedSections = !!nextUnvisitedSection(navStructure);

        // Enter SURVEY from BOOT when we have nav structure (even if classified as feed, not nav_hub)
        if (modeManager.currentMode === MODE.BOOT && hasUnvisitedSections &&
          (classification.type === 'navigation_hub' || fp === homeFingerprint)) {
          modeManager.enterMode(MODE.SURVEY);
        }

        // Also: force survey when repeatedly landing on home with unvisited tabs
        // This catches cases where SURVEY was skipped or exited prematurely
        if (fp === homeFingerprint && hasUnvisitedSections &&
          stateGraph.visitCount(fp) > 3 && modeManager.currentMode !== MODE.SURVEY) {
          console.log(`  [survey] Home visited ${stateGraph.visitCount(fp)}x with unvisited tabs — re-entering SURVEY`);
          modeManager.enterMode(MODE.SURVEY);
        }

        if (modeManager.currentMode === MODE.SURVEY) {
          const nextSection = nextUnvisitedSection(navStructure);
          if (nextSection) {
            console.log(`  [survey] Visiting section: ${nextSection.label}`);
            adb.tap(nextSection.bounds.cx, nextSection.bounds.cy);
            await readiness.waitForScreenReady({ timeoutMs: 3000 });
            const sectionIdx = navStructure.sections.indexOf(nextSection);
            const postXml = adb.dumpXml();
            const postFp = fingerprint.compute(postXml);
            markSectionVisited(navStructure, sectionIdx, postFp);
            await exploreScrollDepth(postXml, new Set());
            actionsTaken.push({
              step, type: 'survey_nav', description: `survey: ${nextSection.label}`,
              actionKey: nextSection.actionKey, fromFingerprint: fp,
            });
            modeManager.recordStep();
            continue;
          }
          // All sections visited — advance to EXPLORE
          modeManager.enterMode(MODE.EXPLORE);
        }
      }

      // Mode check: should we enter VERIFY mode?
      if (modeManager.shouldEnterVerify()) {
        modeManager.enterMode(MODE.VERIFY);
      }
    }

    // ── Auth choice navigation: use heuristic/vision to pick the right login method ──
    // After tapping, enters vision-only WebView mode (no UIAutomator XML dumps)
    // because many apps use WebView/Chrome Custom Tab for auth which breaks XML.
    if (
      hasValidCredentials &&
      screenIntent.type === 'auth_choice' &&
      authFillCount < MAX_AUTH_FILLS
    ) {
      const authChoiceFpKey = `auth_choice::${fp}`;
      const authChoiceAttempts = authChoiceRetries.get(authChoiceFpKey) || 0;
      const MAX_AUTH_CHOICE_RETRIES = 2;

      if (authChoiceAttempts < MAX_AUTH_CHOICE_RETRIES) {
        authChoiceRetries.set(authChoiceFpKey, authChoiceAttempts + 1);
        console.log(`  [crawler] Auth choice screen — attempt ${authChoiceAttempts + 1}/${MAX_AUTH_CHOICE_RETRIES}`);

        const hasEmail = credentials.email || credentials.username;
        const hasPhone = credentials.phone;

        let preferredMethod = 'email';
        if (hasEmail) preferredMethod = 'email';
        else if (hasPhone) preferredMethod = 'phone';

        // Try heuristic first: find a button matching our preferred method
        const buttons = systemHandlers.extractButtons(snapshot.xml);
        const emailPatterns = ['email', 'e-mail', 'continue with email', 'sign in with email', 'log in with email', 'use email', 'email address', 'username'];
        const phonePatterns = ['phone', 'continue with phone', 'sign in with phone', 'use phone number'];
        const patterns = preferredMethod === 'email' ? emailPatterns : phonePatterns;

        let matched = null;
        for (const pattern of patterns) {
          matched = buttons.find(b => b.labelLower.includes(pattern));
          if (matched) break;
        }

        if (!matched && vision.budgetRemaining() > 0) {
          const guidance = await vision.getVisionGuidance(
            snapshot.screenshotPath, snapshot.xml,
            {
              classification: 'auth_choice',
              triedCount: authChoiceAttempts,
              goal: `Find and tap the "${preferredMethod}" login option. We have ${preferredMethod} credentials to sign in.`,
              previousAction: lastActionOutcome,
              journal: formatJournal(),
            }
          );
          if (guidance && guidance.mainActions && guidance.mainActions.length > 0) {
            const bestAction = guidance.mainActions.find(a => {
              const desc = (a.description || '').toLowerCase();
              return patterns.some(p => desc.includes(p));
            }) || guidance.mainActions[0];
            matched = { label: bestAction.description, bounds: { cx: bestAction.x, cy: bestAction.y } };
          }
        }

        if (!matched) {
          console.log('  [crawler] Could not find preferred login method — pressing back');
          adb.pressBack();
          await sleep(800);
          continue;
        }

        console.log(`  [crawler] Tapping "${matched.label}" (${preferredMethod} login)`);
        adb.tap(matched.bounds.cx, matched.bounds.cy);
        authFlowActive = true;
        authFlowStepsRemaining = AUTH_FLOW_MAX_STEPS;
        actionsTaken.push({ step, type: 'auth_choice', method: preferredMethod, label: matched.label, fromFingerprint: fp });

        // DO NOT call waitForScreenReady or dumpXml — WebView auth screens
        // crash UIAutomator and corrupt ADB. Use vision-only navigation instead.
        console.log('  [crawler] Entering vision-only WebView auth mode...');
        const webviewResult = await navigateWebViewAuth(screenshotDir, step, credentials, preferredMethod, packageName);
        console.log(`  [crawler] WebView auth result: navigated=${webviewResult.navigated}, steps=${webviewResult.stepsUsed}`);

        if (webviewResult.navigated) {
          authFillCount++;
          consecutiveCaptureFails = 0;
          totalCaptureRecoveries = 0;
        }
        // Let the main loop capture the next screen normally
        await sleep(2000);
        continue;
      }
    }

    if (
      hasValidCredentials &&
      authFillCount < MAX_AUTH_FILLS &&
      (
        screenIntent.type === 'email_login' ||
        screenIntent.type === 'email_signup' ||
        screenIntent.type === 'email_entry' ||
        screenIntent.type === 'phone_entry' ||
        screenIntent.type === 'otp_verification'
      )
    ) {
      const formResult = forms.detectForm(snapshot.xml);

      if (formResult.isForm) {
        const formKey = `${fp}::${formResult.fields.map((f) => f.type).sort().join('|')}`;

        if (!handledFormScreens.has(formKey)) {
          console.log(`  [crawler] Login/signup form detected with ${formResult.fields.length} fields`);

          const fillActions = await forms.fillForm(formResult.fields, credentials, sleep);

          if (fillActions.length > 0) {
            handledFormScreens.add(formKey);
            filledFingerprints.add(fp);
            authFillCount++;
            authFlowActive = true;
            authFlowStepsRemaining = AUTH_FLOW_MAX_STEPS;

            actionsTaken.push({
              step,
              type: 'form_fill',
              fields: fillActions,
              fromFingerprint: fp,
            });

            await readiness.waitForScreenReady({ timeoutMs: 3000 });

            const submitXml = adb.dumpXml();
            const submitCandidates = actions.extract(submitXml);
            const submitBtn = findBestAuthSubmitAction(submitCandidates);

            if (submitBtn) {
              const submitKey = makeAuthSubmitKey(submitBtn);

              if (submitKey === lastAuthSubmitKey) {
                consecutiveSameAuthSubmit++;
              } else {
                lastAuthSubmitKey = submitKey;
                consecutiveSameAuthSubmit = 1;
              }

              const submitDescription = executeAction(submitBtn);

              actionsTaken.push({
                step,
                type: 'form_submit',
                description: `Tapped submit: "${submitBtn.text || submitBtn.resourceId}"`,
                fromFingerprint: fp,
              });

              console.log(`  [crawler] ${submitDescription}`);
              console.log('  [crawler] Tapped submit button after form fill');

              if (consecutiveSameAuthSubmit >= MAX_SAME_AUTH_SUBMIT) {
                const xmlNow = adb.dumpXml() || '';
                if (hasValidationErrorText(xmlNow)) {
                  console.log('  [crawler] Validation error detected after repeated auth submit');
                  stopReason = 'auth_validation_error';
                  break;
                }

                console.log('  [crawler] Repeated semantic auth submit loop detected after form fill');
                stopReason = 'auth_submit_loop';
                break;
              }
            } else {
              console.log('  [crawler] No auth submit button found after form fill');
            }

            if (!adb.ensureDeviceReady()) {
              consecutiveDeviceFails++;
              console.log(`  [crawler] Device not ready after form submit (${consecutiveDeviceFails}/${MAX_DEVICE_FAILS})`);
              if (consecutiveDeviceFails >= MAX_DEVICE_FAILS) {
                stopReason = 'device_offline';
                break;
              }
            }

            const postSubmitReady = await readiness.waitForScreenReady({ timeoutMs: 5000 });
            metrics.recordReadinessWait(step, 'screen_ready', postSubmitReady);
            modeManager.recordStep();
            continue;
          }
        }
      }
    }

    // Overlay detection: document picker, share sheet, emoji picker
    if (snapshot.xml) {
      const overlayPkg = getPrimaryPackage(snapshot.xml);
      const isOverlay = overlayPkg === 'com.android.documentsui' ||
        overlayPkg === 'com.android.chooser' ||
        /emoji_picker|share_sheet/i.test(snapshot.xml);
      if (isOverlay) {
        console.log('  [crawler] Overlay/picker detected — dismissing');
        adb.pressBack();
        await readiness.waitForScreenReady({ timeoutMs: 2000 });
        modeManager.recordStep();
        continue;
      }
    }

    // Content creation suppression via classifier
    if (classification && classification.feature === 'content_creation' && step < Math.floor(maxSteps * 0.6)) {
      const createVisits = coverageTracker ? (coverageTracker.categories['content_creation']?.visits || 0) : 0;
      if (createVisits > 3) {
        console.log('  [brain] Content creation area well-visited — pressing back');
        adb.pressBack();
        await readiness.waitForScreenReady({ timeoutMs: 2000 });
        modeManager.recordStep();
        continue;
      }
    }

    // Track consecutive form visits — escape form typing loops
    if (classification && classification.feature === 'data_entry') {
      consecutiveFormVisits++;
      if (consecutiveFormVisits >= 4 && !isNew) {
        console.log(`  [brain] ${consecutiveFormVisits} consecutive form visits — forcing BACK to escape form loop`);
        adb.pressBack();
        actionsTaken.push({ step, type: 'back', description: 'press_back', reason: 'form_loop_escape', fromFingerprint: fp });
        await sleep(500);
        consecutiveFormVisits = 0;
        modeManager.recordStep();
        continue;
      }
    } else {
      consecutiveFormVisits = 0;
    }

    const tried = stateGraph.triedActionsFor(fp);
    let candidates = actions.extract(snapshot.xml, tried);

    const triedScrollDown = tried.has('scroll_down_1') && tried.has('scroll_down_2') && tried.has('scroll_down_3');
    const triedScrollUp = tried.has('scroll_up_1') && tried.has('scroll_up_2');
    if (triedScrollDown && triedScrollUp) {
      const nonScrollCandidates = candidates.filter(
        (a) =>
          a.type !== actions.ACTION_TYPES.SCROLL_DOWN &&
          a.type !== actions.ACTION_TYPES.SCROLL_UP
      );
      if (nonScrollCandidates.length > 0) {
        candidates = nonScrollCandidates;
        console.log('  [crawler] Scroll budget exhausted for this screen - suppressing scroll actions');
      }
    }

    // ── Inject vision-guided actions (coordinates from screenshot analysis) ──
    if (visionResult && visionResult.mainActions && visionResult.mainActions.length > 0) {
      const visionActions = visionResult.mainActions.map((va) => {
        // Fuzzy key: round to nearest 20px so near-identical coords deduplicate
        const fx = Math.round(va.x / 20) * 20;
        const fy = Math.round(va.y / 20) * 20;
        return {
          type: actions.ACTION_TYPES.TAP,
          bounds: { cx: va.x, cy: va.y, x1: va.x - 20, y1: va.y - 20, x2: va.x + 20, y2: va.y + 20 },
          text: va.description || '',
          contentDesc: va.description || '',
          resourceId: '',
          className: '',
          priority: va.priority === 'high' ? 95 : va.priority === 'medium' ? 75 : 45,
          key: `tap:vision:${fx},${fy}`,
          visionGuided: true,
          packageName: packageName,
        };
      });
      const newVisionActions = visionActions.filter((va) => !tried.has(va.key));
      if (newVisionActions.length > 0) {
        candidates = [...newVisionActions, ...candidates];
        console.log(`  [vision] Injected ${newVisionActions.length} vision-guided actions`);
      }
    }

    const isAuthIntent =
      screenIntent.type === 'auth_choice' ||
      screenIntent.type === 'phone_entry' ||
      screenIntent.type === 'email_entry' ||
      screenIntent.type === 'email_login' ||
      screenIntent.type === 'email_signup' ||
      screenIntent.type === 'otp_verification';

    // Fix 4: Allow TYPE on search/form screens — but limit to 1 field per visit
    if (!authFlowActive && !isAuthIntent) {
      const allowType = classification && (classification.type === 'search' || classification.type === 'form');
      if (!allowType) {
        const hasTap = candidates.some((a) => a.type === actions.ACTION_TYPES.TAP);
        if (hasTap) {
          candidates = candidates.filter((a) => a.type !== actions.ACTION_TYPES.TYPE);
          console.log('  [crawler] Suppressing TYPE actions on non-auth screen');
        }
      } else {
        // On form/search: keep only 1 TYPE action so the crawler types once, then explores
        const typeActions = candidates.filter((a) => a.type === actions.ACTION_TYPES.TYPE);
        const nonTypeActions = candidates.filter((a) => a.type !== actions.ACTION_TYPES.TYPE);
        if (typeActions.length > 1) {
          candidates = [typeActions[0], ...nonTypeActions];
          console.log(`  [crawler] Form screen: keeping 1 TYPE action, suppressed ${typeActions.length - 1}`);
        } else {
          console.log(`  [crawler] Allowing TYPE actions on ${classification.type} screen`);
        }
      }
    }

    if (
      primaryPackage === packageName &&
      candidates.length === 1 &&
      candidates[0].type === actions.ACTION_TYPES.BACK
    ) {
      const sparseCount = (visitedCounts.get(`sparse::${fp}`) || 0) + 1;
      visitedCounts.set(`sparse::${fp}`, sparseCount);

      if (sparseCount <= 2) {
        console.log(`  [crawler] In-app sparse screen with only BACK available - recovery attempt ${sparseCount}/2`);
        await recoveryManager.recover(SITUATION.DEAD_END, fp);
        continue;
      }

      console.log('  [crawler] In-app sparse screen persisted after recovery - stopping');
      stopReason = 'in_app_sparse_screen';
      break;
    }

    const isEarlyExploration = step < Math.floor(maxSteps / 2);

    // Deprioritize content-creation actions during early exploration
    if (isEarlyExploration && classification && classification.feature === 'content_creation') {
      candidates = candidates.map(a => {
        if (a.type === actions.ACTION_TYPES.TAP) {
          return { ...a, priority: Math.floor(a.priority / 3) };
        }
        return a;
      });
      console.log('  [crawler] Early exploration: reducing content-creation priority');
    }

    // Never press BACK from the app's home/root screen — it exits the app
    if (fp === homeFingerprint) {
      const beforeCount = candidates.length;
      candidates = candidates.filter(a => a.type !== actions.ACTION_TYPES.BACK);
      if (candidates.length < beforeCount) {
        console.log('  [brain] Home screen — BACK suppressed (would exit app)');
      }

      // Force scroll on home when most tap actions are tried — reveal below-fold content
      const nonScrollNonBack = candidates.filter(
        (a) => a.type !== actions.ACTION_TYPES.SCROLL_DOWN &&
          a.type !== actions.ACTION_TYPES.SCROLL_UP &&
          a.type !== actions.ACTION_TYPES.BACK
      );
      const untriedTaps = nonScrollNonBack.filter((a) => !tried.has(a.key));
      const hasUntried = untriedTaps.length > 0;
      const homeVisits = stateGraph.visitCount(fp);

      if (!hasUntried && homeVisits > 3 && !triedScrollDown) {
        console.log(`  [brain] Home screen: all ${nonScrollNonBack.length} visible taps tried — boosting scroll to reveal new content`);
        const scrollActions = candidates.filter(
          (a) => a.type === actions.ACTION_TYPES.SCROLL_DOWN
        );
        if (scrollActions.length > 0) {
          // Boost scroll priority so it's picked next
          candidates = candidates.map((a) =>
            a.type === actions.ACTION_TYPES.SCROLL_DOWN ? { ...a, priority: 150 } : a
          );
        }
      }
    }

    // Force exploration of new screens — don't leave immediately
    if (fp === lastNewScreenFp && actionsOnNewScreen < 2) {
      const exploreCandidates = candidates.filter(a => {
        if (a.type === actions.ACTION_TYPES.BACK) return false;
        const label = `${a.text || ''} ${a.contentDesc || ''}`.toLowerCase().trim();
        if (label === 'home') return false;
        return true;
      });
      if (exploreCandidates.length > 0) {
        candidates = exploreCandidates;
        console.log('  [brain] New screen — exploring before going back/home');
      }
      actionsOnNewScreen++;
    }

    // Deprioritize "Home" button if we've been home many times already
    if (homeFingerprint && stateGraph.visitCount(homeFingerprint) > 3) {
      candidates = candidates.map(a => {
        const label = `${a.text || ''} ${a.contentDesc || ''}`.toLowerCase().trim();
        if (label === 'home') return { ...a, priority: Math.max(a.priority - 40, 5) };
        return a;
      });
    }

    if (screenIntent.type === 'auth_choice' || screenIntent.type === 'phone_entry' || screenIntent.type === 'email_entry') {
      const authSubmit = findBestAuthSubmitAction(candidates);
      if (authSubmit) {
        candidates = [authSubmit, ...candidates.filter((a) => a.key !== authSubmit.key)];
        console.log(`  [intent] Prioritizing auth CTA for ${screenIntent.type}`);
      }
    }

    if (filledFingerprints.has(fp) || authFlowActive || screenIntent.type.startsWith('auth') || screenIntent.type.includes('login') || screenIntent.type.includes('signup') || screenIntent.type === 'email_entry' || screenIntent.type === 'phone_entry' || screenIntent.type === 'otp_verification') {
      const authSubmit = findBestAuthSubmitAction(candidates, screenIntent.type);

      if (authSubmit) {
        const authKey = makeAuthSubmitKey(authSubmit);

        if (authKey === lastAuthSubmitKey) {
          consecutiveSameAuthSubmit++;
        } else {
          lastAuthSubmitKey = authKey;
          consecutiveSameAuthSubmit = 1;
        }

        if (consecutiveSameAuthSubmit >= MAX_SAME_AUTH_SUBMIT) {
          if (hasValidationErrorText(snapshot.xml)) {
            console.log('  [crawler] Validation error detected on repeated auth CTA screen');
            stopReason = 'auth_validation_error';
            break;
          }

          console.log('  [crawler] Repeated semantic auth submit loop detected');
          stopReason = 'auth_submit_loop';
          break;
        }

        candidates = [
          authSubmit,
          ...candidates.filter((a) => a.key !== authSubmit.key && a.type !== actions.ACTION_TYPES.TYPE),
        ];
        console.log('  [crawler] Prioritizing auth CTA in auth flow');
      } else {
        candidates = candidates.filter((a) => a.type !== actions.ACTION_TYPES.TYPE);
        console.log('  [crawler] Suppressing extra TYPE actions in auth flow');
      }
    } else {
      lastAuthSubmitKey = null;
      consecutiveSameAuthSubmit = 0;
    }

    // ── Credential-aware auth choice boost ──
    // When on an auth_choice screen with credentials, boost actions matching
    // our credential type so the policy engine picks email over phone/google.
    if (hasValidCredentials && screenIntent.type === 'auth_choice') {
      const hasEmail = credentials.email || credentials.username;
      const hasPhone = credentials.phone;

      candidates = candidates.map(a => {
        const hay = `${a.text || ''} ${a.contentDesc || ''}`.toLowerCase();
        if (hasEmail && (hay.includes('email') || hay.includes('username'))) {
          return { ...a, priority: a.priority + 50 };
        }
        if (hasPhone && hay.includes('phone')) {
          return { ...a, priority: a.priority + 50 };
        }
        if (hasEmail && (hay.includes('google') || hay.includes('apple') || hay.includes('facebook'))) {
          return { ...a, priority: Math.max(a.priority - 30, 0) };
        }
        return a;
      });
      console.log('  [crawler] Applied credential-aware auth boost');
    }

    // Apply plan boost — prioritize actions that match the current exploration target
    if (plan && planBoost) {
      candidates = candidates.map(a => ({
        ...a,
        priority: a.priority + planBoost(a, plan),
      }));
    }

    // Defer destructive actions until late in the crawl (VERIFY mode)
    if (modeManager.budgetUsedPercent() < 0.85) {
      const beforeCount = candidates.length;
      candidates = candidates.filter(a => !appState.isDestructiveAction(a));
      if (candidates.length < beforeCount) {
        console.log(`  [appState] ${beforeCount - candidates.length} destructive action(s) deferred to VERIFY mode`);
      }
    }

    console.log(`  [crawler] ${candidates.length} candidate actions (${tried.size} already tried)`);

    const decision = policy.choose(candidates, stateGraph, fp, {
      goldenPath,
      goals,
      painPoints,
    });

    if (decision.action.type === 'stop') {
      console.log(`  [crawler] Policy says stop: ${decision.reason}`);
      stopReason = decision.reason;
      break;
    }

    if (classification && classification.feature === 'content_creation') {
      console.log('  [crawler] Content-creation action selected');
    }

    const currentPackage = getPrimaryPackage(snapshot.xml);
    const pM = currentPackage === packageName;
    const tM = decision?.action?.type === 'back' || decision?.action?.type === actions.ACTION_TYPES.BACK;
    const rM = ['loop_detected', 'max_revisits_exceeded', 'all_actions_exhausted'].includes(decision.reason);

    // Defense-in-depth: check if there are effective untried actions despite backtrack decision
    const ineffectiveSet = stateGraph.badActionsFor(fp);
    const effectiveUntriedCount = candidates.filter(a => !tried.has(a.key) && !ineffectiveSet.has(a.key)).length;

    console.log(`[DEBUG] Intercept Evaluator - pkgMatch:${pM} typeMatch:${tM} reasonMatch:${rM} effectiveUntried:${effectiveUntriedCount}`);

    // Only recover if truly no effective untried actions remain
    const shouldSubstituteRecoveryRelaunch = tM && rM && pM && effectiveUntriedCount === 0;

    if (shouldSubstituteRecoveryRelaunch) {
      const situation = decision.reason === 'loop_detected' ? SITUATION.LOOP_DETECTED : SITUATION.ALL_EXHAUSTED;
      console.log(`  [crawler] Recovery for ${situation} (0 untried actions)`);

      const recResult = await recoveryManager.recover(situation, fp);
      actionsTaken.push({
        step,
        type: 'recovery',
        description: `recovery_${recResult.strategy}(${recResult.success ? 'ok' : 'fail'})`,
        reason: `recovery_for_${decision.reason}`,
        actionKey: `recovery_${recResult.strategy}`,
        fromFingerprint: fp,
      });

      if (!recResult.success) {
        console.log(`  [recovery] All strategies failed for ${situation}`);
      }
      modeManager.recordStep();
      continue;
    }

    // Clear logcat buffer before action (for crash/ANR detection)
    adb.run('adb logcat -c', { ignoreError: true });
    const preActionTimestamp = Date.now();

    const description = executeAction(decision.action);
    console.log(`  [crawler] Executed: ${description} (reason: ${decision.reason})`);

    // Update live feed with the action just taken
    lastLiveAction = {
      type: decision.action.type,
      description,
      decisionSource: decision.reason,
    };
    sendLiveProgress(step, {
      activity: snapshot.activity || '',
      intentType: screenIntent.type || '',
      message: `Executed: ${description}`,
    });

    if (!adb.ensureDeviceReady()) {
      consecutiveDeviceFails++;
      console.log(`  [crawler] Device not ready after action (${consecutiveDeviceFails}/${MAX_DEVICE_FAILS})`);
      if (consecutiveDeviceFails >= MAX_DEVICE_FAILS) {
        stopReason = 'device_offline';
        break;
      }
      await sleep(3000);
      continue;
    }

    const actionKey = decision.action.key || description;
    lastActionKey = actionKey;
    lastActionFromFp = fp;
    actionsTaken.push({
      step,
      type: decision.action.type,
      description,
      reason: decision.reason,
      actionKey,
      fromFingerprint: fp,
    });

    // Record step in flow tracker with actual action details
    if (flowTracker) {
      const actionTarget = decision.action.text || decision.action.resourceId || '';
      flowTracker.addStep(
        classification ? classification.type : 'unknown',
        decision.action.type,
        actionTarget,
        fp
      );
    }

    const readyResult = await readiness.waitForScreenReady({ timeoutMs: 5000 });
    metrics.recordReadinessWait(step, 'screen_ready', readyResult);

    const postSnapshot = await captureStableScreen(screenshotDir, `${step}_post`, 2, 1500);

    if (postSnapshot && !postSnapshot.error && !isTransientEmptyXml(postSnapshot.xml)) {
      const postFp = fingerprint.compute(postSnapshot.xml);
      stateGraph.addTransition(fp, actionKey, postFp);

      // Classify transition type for metrics
      let transitionType = 'same_screen';
      const postPkg = getPrimaryPackage(postSnapshot.xml);
      if (postFp !== fp) {
        if (postPkg && postPkg !== packageName && !isAllowedNonTargetPackage(postPkg)) {
          transitionType = 'left_app';
        } else {
          transitionType = stateGraph.isVisited(postFp) ? 'back_to_known' : 'new_screen';
        }
      }

      // ── Outcome feedback: record what happened for the next vision call ──
      const outcomeType = postFp === fp ? 'no_change'
        : transitionType === 'left_app' ? 'left_app'
          : transitionType === 'new_screen' ? 'new_screen'
            : 'known_screen';
      lastActionOutcome = {
        action: {
          type: decision.action.type,
          target: decision.action.text || decision.action.resourceId || decision.action.contentDesc || '',
        },
        outcome: {
          type: outcomeType,
          postActivity: postSnapshot.activity || null,
        },
      };

      // ── Exploration journal: append this step ──
      explorationJournal.push({
        step,
        screen: classification ? (classification.feature || classification.type || 'unknown') : 'unknown',
        action: decision.action.text || decision.action.type || 'unknown',
        outcome: outcomeType,
        isNew: transitionType === 'new_screen',
      });
      if (explorationJournal.length > JOURNAL_MAX) explorationJournal.shift();

      const settleMeta = { settleTimeMs: readyResult.elapsedMs };

      // Track ineffective taps — tap that didn't change the screen
      if (postFp === fp) {
        stateGraph.recordOutcome(fp, actionKey, 'ineffective', settleMeta);
        metrics.recordActionOutcome(step, 'ineffective', transitionType);
        consecutiveIneffectiveTaps++;
        if (consecutiveIneffectiveTaps >= 3) {
          console.log(`  [brain] ${consecutiveIneffectiveTaps} consecutive ineffective taps — forcing recovery`);
          if (fp === homeFingerprint) {
            // At home screen — BACK would exit app, use recovery instead
            await recoveryManager.recover(SITUATION.DEAD_END, fp);
          } else {
            adb.pressBack();
            await sleep(1000);
            // Verify app is still in foreground after BACK
            const postBackXml = adb.dumpXml() || '';
            const postBackPkg = getPrimaryPackage(postBackXml);
            if (postBackPkg && postBackPkg !== packageName) {
              console.log(`  [brain] BACK dropped to ${postBackPkg} — relaunching ${packageName}`);
              if (launcherActivity) {
                adb.run(`adb shell am start -n ${packageName}/${launcherActivity}`, { ignoreError: true });
              } else {
                adb.run(`adb shell monkey -p ${packageName} -c android.intent.category.LAUNCHER 1`, { ignoreError: true });
              }
              await sleep(2000);
            }
          }
          consecutiveIneffectiveTaps = 0;
          modeManager.recordStep();
          continue;
        }
      } else {
        consecutiveIneffectiveTaps = 0;
        // Check for dead-end: screen with no interactable elements
        const postActions = actions.extract(postSnapshot.xml, new Set());
        const hasUsefulActions = postActions.some(a => a.type !== 'back');
        if (!hasUsefulActions) {
          const prevOutcome = stateGraph.getOutcome(fp, actionKey);
          if (prevOutcome === 'dead_end_1') {
            stateGraph.recordOutcome(fp, actionKey, 'dead_end', settleMeta);
            metrics.recordActionOutcome(step, 'dead_end', transitionType);
            console.log(`  [crawler] Action "${actionKey}" -> dead_end (permanent, 2nd time)`);
          } else {
            stateGraph.recordOutcome(fp, actionKey, 'dead_end_1', settleMeta);
            metrics.recordActionOutcome(step, 'dead_end_1', transitionType);
            console.log(`  [crawler] Action "${actionKey}" -> dead_end_1 (will retry once after recovery)`);
            await recoveryManager.recover(SITUATION.DEAD_END, fp);
          }
        } else {
          stateGraph.recordOutcome(fp, actionKey, 'ok', settleMeta);
          metrics.recordActionOutcome(step, 'ok', transitionType);
        }
      }
    } else if (postSnapshot && postSnapshot.error === 'device_offline') {
      consecutiveDeviceFails++;
      console.log(`  [crawler] Device lost during post-action capture (${consecutiveDeviceFails}/${MAX_DEVICE_FAILS})`);
      if (consecutiveDeviceFails >= MAX_DEVICE_FAILS) {
        stopReason = 'device_offline';
        break;
      }
    } else if (postSnapshot && postSnapshot.error === 'capture_failed') {
      consecutiveCaptureFails++;
      console.log(`  [crawler] Post-action screenshot capture failed (${consecutiveCaptureFails}/${MAX_CAPTURE_FAILS})`);
      if (consecutiveCaptureFails >= MAX_CAPTURE_FAILS) {
        totalCaptureRecoveries++;
        if (totalCaptureRecoveries > MAX_CAPTURE_RECOVERIES) {
          console.log(`  [crawler] Post-action capture recovery failed ${totalCaptureRecoveries} times total — giving up`);
          stopReason = 'capture_failed';
          break;
        }
        console.log(`  [crawler] Max post-action capture fails — attempting recovery (${totalCaptureRecoveries}/${MAX_CAPTURE_RECOVERIES})`);
        const recResult = await recoveryManager.recover(SITUATION.EMPTY_SCREEN, 'capture_failed');
        if (recResult.success) {
          console.log('  [crawler] Recovery succeeded after post-action capture failures — resuming');
          consecutiveCaptureFails = 0;
          continue;
        }
        stopReason = 'capture_failed';
        break;
      }
    }

    modeManager.recordStep();
    metrics.recordStepEnd(step);

    // ── Oracle checks: crash, ANR, accessibility, slow transitions (FREE bug detection) ──
    const stepFindings = [];

    // Crash detection via logcat
    try {
      const logcat = adb.run('adb logcat -d -s AndroidRuntime:E', { ignoreError: true });
      if (logcat && /FATAL EXCEPTION/.test(logcat)) {
        stepFindings.push({ type: 'crash', severity: 'critical', detail: logcat.substring(0, 500), step });
        console.log(`  [oracle] CRASH DETECTED at step ${step}!`);
      }
    } catch (e) { /* logcat check failed, non-critical */ }

    // ANR detection
    try {
      const anrCheck = adb.run('adb shell dumpsys activity processes | grep ANR', { ignoreError: true });
      if (anrCheck && anrCheck.trim() && /ANR in/.test(anrCheck)) {
        stepFindings.push({ type: 'anr', severity: 'high', detail: anrCheck.trim().substring(0, 300), step });
        console.log(`  [oracle] ANR DETECTED at step ${step}!`);
      }
    } catch (e) { /* ANR check failed, non-critical */ }

    // Accessibility: missing content descriptions on clickable elements
    if (snapshot.xml) {
      const clickableNodes = (snapshot.xml.match(/clickable="true"/g) || []).length;
      const emptyDescNodes = (snapshot.xml.match(/clickable="true"[^>]*content-desc=""/g) || []).length;
      if (clickableNodes > 3 && emptyDescNodes > clickableNodes * 0.5) {
        stepFindings.push({
          type: 'missing_content_description', severity: 'medium',
          detail: `${emptyDescNodes}/${clickableNodes} clickable elements lack content descriptions`,
          step, element: snapshot.activity || 'unknown'
        });
      }

      // Accessibility: small tap targets
      const smallTargets = [];
      const boundsRegex = /clickable="true"[^>]*bounds="\[(\d+),(\d+)\]\[(\d+),(\d+)\]"/g;
      let bm;
      while ((bm = boundsRegex.exec(snapshot.xml)) !== null) {
        const w = parseInt(bm[3]) - parseInt(bm[1]);
        const h = parseInt(bm[4]) - parseInt(bm[2]);
        if (w < 44 || h < 44) smallTargets.push({ w, h });
      }
      if (smallTargets.length > 3) {
        stepFindings.push({
          type: 'small_tap_target', severity: 'low',
          detail: `${smallTargets.length} tap targets smaller than 44px (WCAG minimum 48dp)`,
          step, element: snapshot.activity || 'unknown'
        });
      }
    }

    // Slow transition detection
    const transitionTime = Date.now() - preActionTimestamp;
    const slowThresholdMs = require('../config/defaults').SLOW_RESPONSE_THRESHOLD_MS || 12000;
    if (transitionTime > slowThresholdMs) {
      stepFindings.push({
        type: 'slow_transition', severity: 'low',
        detail: `Screen transition took ${transitionTime}ms (threshold: ${slowThresholdMs}ms)`,
        step
      });
      console.log(`  [oracle] Slow transition: ${transitionTime}ms`);
    }

    if (stepFindings.length > 0) {
      oracleFindingsByStep[step] = stepFindings;
      console.log(`  [oracle] ${stepFindings.length} finding(s) at step ${step}: ${stepFindings.map(f => f.type).join(', ')}`);
    }
  }

  // Flatten oracle findings for the report pipeline
  const oracleFindings = [];
  for (const [stepNum, findings] of Object.entries(oracleFindingsByStep)) {
    for (const f of findings) oracleFindings.push(f);
  }
  if (oracleFindings.length > 0) {
    console.log(`[crawler] Oracle found ${oracleFindings.length} issue(s): ${oracleFindings.map(f => f.type).join(', ')}`);
  }

  const result = {
    screens: screens.map((s) => ({
      index: s.index,
      step: s.step,
      path: s.screenshotPath,
      activity: s.activity,
      timestamp: s.timestamp,
      xml: s.xml,
      screenType: s.screenType || 'unknown',
      feature: s.feature || 'other',
      fuzzyFp: s.fuzzyFp || '',
    })),
    actionsTaken,
    graph: stateGraph.toJSON(),
    stopReason,
    reproPath: stateGraph.history,
    stats: {
      totalSteps: screens.length,
      uniqueStates: stateGraph.uniqueStateCount(),
      totalTransitions: stateGraph.transitions.length,
      recoveryStats: recoveryManager.getStats(),
    },
    // Enriched data for oracle pipeline and report builder
    oracleFindings,
    oracleFindingsByStep,
    coverage: coverageTracker ? coverageTracker.summary() : {},
    plan: plan || null,
    flows: flowTracker ? flowTracker.getFlows() : [],
    metrics: metrics.summary({
      totalSteps: screens.length,
      uniqueStates: stateGraph.uniqueStateCount(),
    }),
  };

  // Signal crawl complete to live feed
  if (onProgress) {
    onProgress({
      phase: 'analyzing',
      rawStep: maxSteps,
      maxRawSteps: maxSteps,
      countedUniqueScreens: stateGraph.uniqueStateCount(),
      targetUniqueScreens: maxSteps,
      activity: '',
      intentType: '',
      latestAction: lastLiveAction,
      message: 'Crawl complete: ' + result.stats.uniqueStates + ' unique screens. Analyzing...',
      captureMode: 'screenshot',
      packageName,
    });
  }

  console.log(
    `\n[crawler] Crawl complete: ${result.stats.totalSteps} steps, ${result.stats.uniqueStates} unique states, stop reason: ${stopReason}`,
  );

  const artifactPath = `${screenshotDir}/crawl_artifacts.json`;
  fs.writeFileSync(artifactPath, JSON.stringify(result, null, 2));
  console.log(`[crawler] Artifacts saved to ${artifactPath}`);

  return result;
}

module.exports = { runCrawl };
