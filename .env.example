# ProdScope Backend — Required Environment Variables
# Copy this file to .env and fill in your values.

# ─── LLM ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Authentication ────────────────────────────────────
# JWT secret for token signing (min 32 chars, generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=

# API key for programmatic access (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
PRODSCOPE_API_KEY=

# Google OAuth 2.0 Client ID for Google Sign-In (see docs/SETUP_GOOGLE_OAUTH.md).
# Web app is the only flow; no client secret required — verification uses
# the Client ID as the audience. Must match VITE_GOOGLE_CLIENT_ID in frontend/.env.
GOOGLE_CLIENT_ID=

# Comma-separated list of emails that get 'admin' role on first Google sign-in.
# Used for /admin/partners and future admin routes.
ADMIN_EMAILS=arjunhn57@gmail.com

# ─── CORS ──────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty to allow all in dev)
CORS_ALLOWED_ORIGINS=

# ─── Server ────────────────────────────────────────────
PORT=8080
NODE_ENV=production

# ─── Database ──────────────────────────────────────────
# DB_PATH=./data/prodscope.db

# ─── Emulator ─────────────────────────────────────────
# SNAPSHOT_NAME=prodscope-ready

# ─── Alerting (optional) ──────────────────────────────
# Webhook URL for Slack/Discord alerts on failures, disk critical, etc.
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Logging ──────────────────────────────────────────
# LOG_LEVEL=info

# ─── Email (optional) ─────────────────────────────────
# RESEND_API_KEY=re_...

# ─── Shareable reports (magic-link) ───────────────────
# HMAC secret used to sign per-job magic-link tokens for /r/:jobId URLs.
# Must be at least 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Rotating this secret invalidates every outstanding shareable link.
MAGIC_LINK_SECRET=

# Public-facing origin used to build shareable URLs in outbound emails, e.g.
#   PUBLIC_APP_URL=https://prodscope.example.com
# In dev, leave blank — the backend will fall back to the request's Host header.
PUBLIC_APP_URL=
