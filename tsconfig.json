{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "incremental": true,
    "types": ["node"]
  },
  "include": ["crawler/**/*", "jobs/**/*", "lib/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.js",
    "**/__tests__/**",
    "crawler/_v15-archive/**",
    "crawler/**/*.before_*",
    "crawler/**/*.bak_*"
  ]
}
